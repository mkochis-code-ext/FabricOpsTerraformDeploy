tenant_id = "00000000-0000-0000-0000-000000000000"
client_id = "00000000-0000-0000-0000-000000000000"
use_oidc  = true

workspace_display_name = "FabricOps-Dev"
workspace_description  = "Development workspace managed by Terraform."

# Optional: assign a dedicated capacity.
# capacity_id = "00000000-0000-0000-0000-000000000000"

# Git integration: connect the Dev workspace to the Azure DevOps repository.
enable_git_integration      = true
git_connection_id           = "11111111-1111-1111-1111-111111111111"
git_organization_name       = "MyOrg"
git_project_name            = "MyProject"
git_repository_name         = "FabricOpsTerraformDeploy"
git_branch_name             = "main"
git_directory_name          = "/Fabric"
git_initialization_strategy = "PreferRemote"
